{
  "model": {
    "vocab_size": 6400,
    "dim": 512,
    "num_q_heads": 8,
    "num_kv_heads": 4,
    "num_layers": 8,
    "max_seq_len": 512
  },
  "training": {
    "batch_size": 64,
    "seq_len": 512,
    "max_steps": 50000,
    "warmup_steps": 200,
    "lr": 6e-4,
    "min_lr_ratio": 0.1,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "log_every": 100,
    "eval_every": 500,
    "save_every": 1000,
    "out_dir": "out/pretrain"
  },
  "data": {
    "train_path": "data/pretrain_clean/train.bin",
    "valid_path": "data/pretrain_clean/valid.bin",
    "tokenizer_path": "data/pretrain_clean/tokenizer.json"
  }
}